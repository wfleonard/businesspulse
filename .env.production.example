# Production env for the Linode app node. Copy to `.env` on the server and fill in.
# NEVER commit the real .env. Compose reads this via env_file.

# --- Managed Postgres (Linode Managed Database), dedicated app role ---
# Build from the cluster's connection info, swapping akmadmin/defaultdb for your
# app role + database. Keep sslmode=require.
DATABASE_URL=postgres://bp_app:CHANGE_ME@<host>.akamaidb.net:23200/businesspulse?sslmode=require

# --- Valkey (container on this node) ---
# REDIS_URL is assembled by compose from VALKEY_PASSWORD — just set the password.
VALKEY_PASSWORD=CHANGE_ME_long_random

# --- Auth (better-auth) ---
# openssl rand -base64 48
BETTER_AUTH_SECRET=CHANGE_ME
BETTER_AUTH_URL=https://businesspulse.app
BP_ALLOW_SIGNUP=false

# --- Public app URL (inlined at build; also used at runtime) ---
NEXT_PUBLIC_APP_URL=https://businesspulse.app

# --- Connector credential encryption (AES-256-GCM) ---
# openssl rand -base64 32
CONNECTOR_ENC_KEY=CHANGE_ME

# --- AI (Anthropic) ---
ANTHROPIC_API_KEY=CHANGE_ME

# --- Email (Mailtrap) ---
MAILTRAP_API_TOKEN=CHANGE_ME
MAILTRAP_SENDER=alerts@businesspulse.app

# --- Cron trigger guard ---
# openssl rand -hex 24
CRON_SECRET=CHANGE_ME
