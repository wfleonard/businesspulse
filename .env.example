# BusinessPulse — Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# --- Postgres (managed: Linode Managed DB or Neon) ---
DATABASE_URL=postgres://user:pass@host:5432/businesspulse?sslmode=require
# Set to "disable" only for a local non-TLS Postgres in dev.
DATABASE_SSL=require
DATABASE_POOL_MAX=10

# --- Redis / Valkey (managed, TCP; rediss:// for TLS) ---
REDIS_URL=rediss://default:pass@host:6379

# --- Auth (better-auth) ---
# Generate: openssl rand -base64 48
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://businesspulse.app
# Open registration (default false — single-user MVP is seeded, not self-serve).
BP_ALLOW_SIGNUP=false

# --- Public app URL (used by the browser auth client) ---
NEXT_PUBLIC_APP_URL=https://businesspulse.app

# --- Connector credential encryption (AES-256-GCM) ---
# Generate: openssl rand -base64 32
CONNECTOR_ENC_KEY=

# --- AI (Anthropic) — added in Stage 3 ---
ANTHROPIC_API_KEY=

# --- Email (Mailtrap) — added in Stage 4 ---
MAILTRAP_API_TOKEN=
MAILTRAP_SENDER=alerts@businesspulse.app

# --- Cron trigger guard (manual /api/cron/* re-sync) ---
CRON_SECRET=
